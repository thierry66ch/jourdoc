{
  "name": "jourdoc",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/dev.js\"",
    "build": "vite build",
    "start": "node server/dev.js",
    "db:init": "node -e \"import('./db/db.js').then(m => m.initSchema())\"",
    "db:migrate": "node db/migrate.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@neondatabase/serverless": "^0.10.4",
    "bcrypt": "^5.1.1",
    "exifreader": "^4.23.0",
    "heic-convert": "^2.1.0",
    "hono": "^4.6.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "sharp": "^0.33.4",
    "uuid": "^10.0.0",
    "webdav": "^5.7.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "workbox-core": "^7.0.0",
    "workbox-precaching": "^7.0.0"
  }
}
