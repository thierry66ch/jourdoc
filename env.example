# JourDoc V2 — Variables d'environnement
# Copier vers .env.local et remplir les valeurs.
# Ce fichier peut être commité (pas de secrets). .env.local ne doit JAMAIS l'être.

# ─── Base de données Neon (PostgreSQL) ───────────────────────────────────────
# Obtenir depuis : console.neon.tech → votre projet → Connection string
# Région recommandée : eu-central-1 (Frankfurt)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/jourdoc?sslmode=require

# ─── Auth JWT ─────────────────────────────────────────────────────────────────
# Générer : openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=ton@email.com

# ─── Email (OTP admin) ────────────────────────────────────────────────────────
# Si vide en dev, l'OTP est affiché dans le terminal (fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── WebDAV KDrive Infomaniak ─────────────────────────────────────────────────
# URL WebDAV Infomaniak (ne pas modifier)
WEBDAV_URL=https://connect.drive.infomaniak.com
# Email du compte Infomaniak
WEBDAV_USER=ton@email.com
# Mot de passe d'APPLICATION KDrive (pas le mot de passe principal du compte)
# Créer depuis : manager.infomaniak.com → kDrive → Paramètres → Mots de passe d'application
WEBDAV_PASSWORD=

# ─── Chemins WebDAV JourDoc ───────────────────────────────────────────────────
# Ces chemins sont paramétrables sans toucher au code.
# Créer ces dossiers sur KDrive avant le premier démarrage.
WEBDAV_PATH_UPLOADS=/pogil.ch/Apps_datas/JourDoc/uploads
WEBDAV_PATH_INBOX=/pogil.ch/Apps_datas/JourDoc/inbox

# ─── Todoist ──────────────────────────────────────────────────────────────────
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
# En développement local
VITE_API_URL=http://localhost:3000
# En production (à mettre dans les env vars Vercel)
# VITE_API_URL=https://jourdoc.pogil.ch

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
